# ⚠️  REQUIRED: Generate a strong random secret key (at least 32 characters)
#    Example: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-this-with-a-generated-random-key-at-least-32-chars-long

# Database
DB_PASSWORD=replace-this-with-a-strong-database-password
DATABASE_URL=postgresql://spectrum4:${DB_PASSWORD}@db:5432/spectrum4_crm

# Application
DEBUG=false

# Session / CSRF
HTTPS_ONLY=true
SAME_SITE=strict

# Email (SMTP relay)
SMTP_HOST=10.0.9.1
SMTP_PORT=10025
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=crm@spectrum4.ca
MAIL_FROM_NAME=Spectrum 4 Strata Council

# Listmonk (bulk email)
LISTMONK_BASE_URL=http://listmonk:9000
LISTMONK_USERNAME=listmonk
LISTMONK_PASSWORD=replace-this-with-a-strong-listmonk-password

# File storage
UPLOADS_DIR=/app/uploads
